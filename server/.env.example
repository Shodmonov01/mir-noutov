# Скопируй в .env в папке server/ — переменные подхватываются через dotenv при импорте config.ts
# Среда: development | production
NODE_ENV=development

# Порт HTTP-сервера (по умолчанию 3000)
PORT=3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mir-noutov

# Telegram Bot token (для проверки X-Telegram-Init-Data)
BOT_TOKEN=123456:ABC-DEF

# JWT для админки
JWT_SECRET=change-me-to-long-random-string
# Срок жизни токена (по умолчанию 7d)
JWT_EXPIRES_IN=7d

# Cloudflare R2 (S3-совместимый endpoint)
R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=mir-noutov
# Публичный базовый URL для отдачи файлов (без завершающего /)
R2_PUBLIC_URL=https://cdn.example.com

# CORS: один origin или * (для Mini App укажи домен фронта)
CORS_ORIGIN=*
